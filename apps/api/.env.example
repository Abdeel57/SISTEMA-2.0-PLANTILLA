# ─────────────────────────────────────────────
# API — variables de entorno (ejemplo, desarrollo)
# Copia este archivo a .env y rellena los valores.
# ─────────────────────────────────────────────

# Entorno
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# Base de datos PostgreSQL (en Railway la inyecta el plugin Postgres)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bismark?schema=public"

# Seguridad
# Genera secretos largos y aleatorios (>= 32 chars). NO los compartas.
JWT_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio-min-32-chars"
COOKIE_SECRET="cambia-esto-por-otro-secreto-largo-y-aleatorio-min-32-chars"
JWT_EXPIRES_IN="7d"
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# Usuario administrador inicial (lo crea el seed; idempotente).
ADMIN_USER=Sortea
ADMIN_PASSWORD=admin123
# Nombre inicial de la página (se edita después desde /admin → Perfil).
SITE_NAME="Mi Página de Rifas"

# URL pública del sitio. Vacía = se infiere del host de cada petición
# (recomendado: frontend y API comparten origen).
PUBLIC_WEB_URL=

# ─────────────────────────────────────────────
# Monitoreo de errores (Sentry) — opcional. Sin DSN no se inicializa nada.
# ─────────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0

# ─────────────────────────────────────────────
# Web Push (avisos al organizador) — opcional.
# Genera claves con: npx web-push generate-vapid-keys
# ─────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ─────────────────────────────────────────────
# Almacenamiento de archivos (logos, portadas, premios, comprobantes, videos)
# Driver: "local" (también usado con Volumen de Railway) | "cloudinary" | "s3"
#
# PRODUCCIÓN (Railway): usa un VOLUMEN persistente.
#   1. En el servicio agrega un Volume (ej. montado en /data).
#   2. Deja STORAGE_DRIVER=local y LOCAL_UPLOAD_DIR=/data/uploads
# ─────────────────────────────────────────────
STORAGE_DRIVER=local
# Carpeta local. En dev: ./uploads. En Railway con Volume: /data/uploads
LOCAL_UPLOAD_DIR=./uploads

# Cloudinary (driver=cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=bismark

# S3 compatible (driver=s3) — AWS S3, Cloudflare R2, MinIO, etc.
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
