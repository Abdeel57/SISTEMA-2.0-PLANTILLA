# ─────────────────────────────────────────────────────────────
# Web — variables de PRODUCCIÓN.
# vite build carga este archivo automáticamente. Solo se exponen al
# navegador las variables con prefijo VITE_. Ninguna es secreta.
#
# El frontend y la API viven en el MISMO servicio de Railway, así que la
# API siempre está en /api del propio dominio.
# ─────────────────────────────────────────────────────────────

VITE_API_URL=/api
VITE_BRAND_NAME=Sortea - Digital

# WhatsApp de Sortea (pie de página "Desarrollado por Sortea").
# Número con código de país, sin "+". Ej: 5216621234567
VITE_BISMARK_WHATSAPP=

# Opcionales (analítica / monitoreo). Vacío = desactivado.
# VITE_SENTRY_DSN=
# VITE_POSTHOG_KEY=
# VITE_POSTHOG_HOST=https://us.i.posthog.com
