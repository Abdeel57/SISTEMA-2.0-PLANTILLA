# ─────────────────────────────────────────────
# Web — variables de entorno (ejemplo)
# Copia a .env.local y ajusta.
# ─────────────────────────────────────────────

# URL base de la API.
# En desarrollo usa el proxy de Vite con "/api" (recomendado, comparte cookies).
# En producción la API vive en /api del mismo servicio.
VITE_API_URL=/api

# Nombre de la marca del desarrollador (pie de página).
VITE_BRAND_NAME=Sortea - Digital

# WhatsApp de Sortea para el pie "Desarrollado por Sortea".
# Número con código de país, sin "+". Ej: 5216621234567. Vacío = sin botón.
VITE_BISMARK_WHATSAPP=

# ─────────────────────────────────────────────
# Monitoreo de errores (Sentry) — opcional. Vacío = desactivado.
# ─────────────────────────────────────────────
VITE_SENTRY_DSN=

# ─────────────────────────────────────────────
# Analítica de producto (PostHog) — opcional. Vacío = desactivado.
# ─────────────────────────────────────────────
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
